/*
 * Custom default U-Boot environment additions for the 'msys' machine.
 *
 * Wired in via CONFIG_ENV_SOURCE_FILE="msys" (see modify_feature.cfg) and
 * copied into the U-Boot tree at board/xilinx/zynqmp/msys.env by the
 * u-boot-xlnx bbappend. U-Boot APPENDS these to the standard Xilinx ZynqMP
 * environment rather than replacing it: env_default.h concatenates
 * CONFIG_EXTRA_ENV_TEXT (generated from this file) after the board's
 * CFG_EXTRA_ENV_SETTINGS.
 *
 * NOTE: this file is run through the C preprocessor, which does NOT strip
 * '#' comments here (assembler-with-cpp mode) -- use C-style comments only.
 *
 * tftpbootstep: one-shot TFTP netboot used during development. Loads the
 * kernel, device tree, ramdisk and boot script (the files exported by
 * export-tftpboot-file.bbclass) and boots. Run it at the U-Boot prompt with:
 *
 *     run tftpbootstep
 *
 * The JTAG loader writes MNCOS_JTAG_MAGIC to DDR before starting U-Boot.
 * CONFIG_PREBOOT consumes the marker, imports optional runtime IP overrides,
 * and starts tftpbootstep. Normal boots never set the marker.
 */
tftpbootstep=tftpboot 0x00200000 Image; tftpboot 0x00100000 system.dtb; fdt addr 0x00100000; fdt get value mncos_bootargs /chosen bootargs; fdt set /chosen bootargs "${mncos_bootargs} mncos.tftp_server=${serverip}"; tftpboot 0x04000000 rootfs.cpio.gz.u-boot; tftpboot 0x20000000 boot.scr; boot
mncos_jtag_use_dhcp=yes
mncos_jtag_magic_addr=0x20000000
mncos_jtag_magic=0x4d4e4350
mncos_jtag_env_magic_addr=0x20000004
mncos_jtag_env_magic=0x49504f56
mncos_jtag_env_addr=0x20000100
mncos_jtag_env_size=0x100
mncos_jtag_import_env=if itest.l *${mncos_jtag_env_magic_addr} == ${mncos_jtag_env_magic}; then mw.l ${mncos_jtag_env_magic_addr} 0 1; env import -t ${mncos_jtag_env_addr} ${mncos_jtag_env_size} mncos_tftp_serverip ipaddr mncos_jtag_use_dhcp; fi
mncos_jtag_boot=setenv serverip ${mncos_tftp_serverip}; echo "MNCOS JTAG TFTP boot: ${ipaddr} -> ${serverip}"; run tftpbootstep
mncos_jtag_preboot=if itest.l *${mncos_jtag_magic_addr} == ${mncos_jtag_magic}; then mw.l ${mncos_jtag_magic_addr} 0 1; run mncos_jtag_import_env; if test -n "${mncos_tftp_serverip}"; then if test "${mncos_jtag_use_dhcp}" = "yes"; then setenv autoload no; if dhcp; then run mncos_jtag_boot; else echo "MNCOS JTAG DHCP failed"; fi; else run mncos_jtag_boot; fi; else echo "MNCOS JTAG TFTP server missing"; fi; fi
